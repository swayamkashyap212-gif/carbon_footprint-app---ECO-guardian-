# ============================================================
# EcoGuardian AI - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Google Vision API (optional - for OCR bill scanning)
EXPO_PUBLIC_GOOGLE_VISION_API_KEY=your-google-vision-api-key

# OpenWeather API (optional - for weather context)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key

# News API (optional - for AI coach context)
NEWS_API_KEY=your-news-api-key

# OpenAI API (optional - for AI coach)
OPENAI_API_KEY=your-openai-api-key

# Email (optional - for email OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Backend Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ecoguardian
JWT_SECRET=your-secure-jwt-secret-min-32-chars
PORT=4000
NODE_ENV=development

# Supabase Edge Functions
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
